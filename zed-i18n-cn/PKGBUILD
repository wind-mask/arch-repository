# Maintainer: wind_mask <YOU KONW WHO>

pkgname="zed-i18n-cn"
pkgver="1.8.2"
pkgrel=1
pkgdesc="Localization toolkit for Zed editor — extract, translate, and build multilingual releases"
arch=('x86_64' 'aarch64')
license=('GPL-3.0-or-later')
url="https://github.com/LI-NA/zed-i18n"
provides=("zed")
conflicts=("zed")
depends=('hicolor-icon-theme' 'zlib' 'alsa-lib' 'glib2' 'glibc' 'libxkbcommon' 'libbsd' 'libmd' 'libxcb' 'util-linux-libs' 'libffi')
source_x86_64=("$pkgname-$pkgver.tar.gz::${url}/releases/download/v${pkgver}-i18n.1/zed-i18n-zh-CN-linux-x86_64.tar.gz")
source_aarch64=("$pkgname-$pkgver.tar.gz::${url}/releases/download/v${pkgver}-i18n.1/zed-i18n-zh-CN-linux-aarch64.tar.gz")
b2sums_x86_64=('5961b083ac0dcfb1d1d410374c9291aa7c39ca82b0c0bae859cae12b80d4b8d50ef7c91a8e8e84268c14bd271564580b2d25bd202fdb519bae64ee85439fb073')
b2sums_aarch64=('5961b083ac0dcfb1d1d410374c9291aa7c39ca82b0c0bae859cae12b80d4b8d50ef7c91a8e8e84268c14bd271564580b2d25bd202fdb519bae64ee85439fb073')
# 解压源码包
prepare() {
  tar -xzf "$pkgname-$pkgver.tar.gz"
}

# 安装到 /opt
package() {
  # 创建目标目录
  install -d "$pkgdir/opt/$pkgname"

  # 复制所有文件到 /opt/软件名
  cp -r "$srcdir/zed.app/"* "$pkgdir/opt/$pkgname/"

  # 设置权限（可选）
  # find "$pkgdir/opt/$pkgname" -type d -exec chmod 755 {} \;
  # find "$pkgdir/opt/$pkgname" -type f -exec chmod 644 {} \;

  # 如果需要：添加可执行文件到系统路径
  install -d "$pkgdir/usr/bin"
  ln -s "/opt/$pkgname/bin/zed" "$pkgdir/usr/bin/zed"

  # 安装图标文件
  _icon_sizes=("512x512" "1024x1024")
  for size in "${_icon_sizes[@]}"; do
    if [ -f "$srcdir/zed.app/share/icons/hicolor/$size/apps/zed.png" ]; then
      install -Dm644 "$srcdir/zed.app/share/icons/hicolor/$size/apps/zed.png" \
        "$pkgdir/usr/share/icons/hicolor/$size/apps/zed.png"
    fi
  done

  # 安装桌面文件
  # 查找任意 .desktop 文件
  desktop_file=$(find "$srcdir/zed.app/share/applications" -maxdepth 1 -name "*.desktop" 2>/dev/null | head -n1)
  install -Dm644 "$desktop_file" "$pkgdir/usr/share/applications/zed.desktop" 
  # 移除调试符号（避免生成debug包）
  find "$pkgdir" -name "*.debug" -delete
  strip --strip-all "$pkgdir/opt/$pkgname/bin/zed" 2>/dev/null || true
  strip --strip-all "$pkgdir/opt/$pkgname/libexec/zed-editor" 2>/dev/null || true

}
# 明确指定不构建debug包
options=('!debug')
